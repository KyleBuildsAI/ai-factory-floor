# Convex
CONVEX_DEPLOYMENT=

# LLM Provider (ollama, openai, anthropic, together, custom)
# Set via: npx convex env set LLM_PROVIDER ollama

# Ollama (default, local)
# npx convex env set OLLAMA_HOST http://localhost:11434
# npx convex env set OLLAMA_MODEL llama3

# OpenAI
# npx convex env set OPENAI_API_KEY sk-...
# npx convex env set OPENAI_CHAT_MODEL gpt-4o-mini

# Anthropic
# npx convex env set ANTHROPIC_API_KEY sk-ant-...

# Together.ai
# npx convex env set TOGETHER_API_KEY ...

# Custom / LiteLLM
# npx convex env set LLM_API_URL http://...
# npx convex env set LLM_API_KEY ...
# npx convex env set LLM_MODEL ...
